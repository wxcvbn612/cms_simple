<!DOCTYPE html>
<html lang="{{ app.request.locale }}" {% if app.request.locale == 'ar' %}dir="rtl"{% endif %}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ settings.siteName }}{% endblock %}</title>

    {% if settings.faviconFilename %}
        <link rel="icon" href="{{ asset('uploads/logo/' ~ settings.faviconFilename) }}">
    {% endif %}

    {# CSS Variables from LandingPageContent (runtime overrides) #}
    <style>
        :root {
            --color-primary:    {{ lp.colorPrimary }};
            --color-secondary:  {{ lp.colorSecondary }};
            --color-bg:         {{ lp.colorBackground }};
            --color-text:       {{ lp.colorText }};
            --color-navbar-bg:  {{ lp.colorNavbarBg }};
            --color-navbar-text:{{ lp.colorNavbarText }};
            --color-footer-bg:  {{ lp.colorFooterBg }};
            --color-footer-text:{{ lp.colorFooterText }};
            --bs-primary:       {{ lp.colorPrimary }};
            --bs-secondary:     {{ lp.colorSecondary }};
        }
        body {
            background-color: var(--color-bg);
            color: var(--color-text);
        }
    </style>

    {# Google Fonts #}
    {% if lp.fontBody or lp.fontHeading %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family={{ lp.fontHeading|replace({' ': '+'}) }}:wght@400;600;700&family={{ lp.fontBody|replace({' ': '+'}) }}:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body    { font-family: '{{ lp.fontBody }}', sans-serif; font-size: {{ lp.fontSizeBase }}; }
        h1,h2,h3,h4,h5 { font-family: '{{ lp.fontHeading }}', sans-serif; }
    </style>
    {% endif %}

    {# Webpack Encore assets — conditional LTR / RTL #}
    {% block stylesheets %}
        {% if app.request.locale == 'ar' %}
            {{ encore_entry_link_tags('app_rtl') }}
        {% else %}
            {{ encore_entry_link_tags('app') }}
        {% endif %}
    {% endblock %}
</head>
<body>
    {% block navbar %}
        {{ include('partials/_navbar.html.twig') }}
    {% endblock %}

    {% for type, messages in app.flashes %}
        <div class="container mt-3">
            {% for message in messages %}
                <div class="alert alert-{{ type == 'success' ? 'success' : (type == 'error' ? 'danger' : type) }} alert-dismissible fade show" role="alert">
                    {{ message|trans }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        </div>
    {% endfor %}

    {% block body %}{% endblock %}

    {% block footer %}
        {{ include('partials/_footer.html.twig') }}
    {% endblock %}

    {% block javascripts %}
        {% if app.request.locale == 'ar' %}
            {{ encore_entry_script_tags('app_rtl') }}
        {% else %}
            {{ encore_entry_script_tags('app') }}
        {% endif %}
    {% endblock %}
</body>
</html>
