<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Admin{% endblock %} — {{ settings.siteName }}</title>
    {{ encore_entry_link_tags('admin') }}
    {% block stylesheets %}{% endblock %}
</head>
<body>

{# Sidebar #}
<aside class="sidebar">
    <div class="brand">
        <i class="bi bi-grid-3x3-gap-fill me-2"></i>Admin
        <div class="small fw-normal text-secondary mt-1">{{ settings.siteName }}</div>
    </div>

    <nav class="mt-2">
        <div class="nav-section">Tableau de bord</div>
        <a href="{{ path('admin_dashboard') }}"
           class="nav-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="nav-section">Contenu</div>
        <a href="{{ path('admin_actualite_index') }}"
           class="nav-link {% if 'admin_actualite' in app.request.attributes.get('_route') %}active{% endif %}">
            <i class="bi bi-newspaper"></i> Actualités
        </a>
        <a href="{{ path('admin_message_index') }}"
           class="nav-link {% if 'admin_message' in app.request.attributes.get('_route') %}active{% endif %}">
            <i class="bi bi-envelope"></i> Messages
            {% set unread = messageRepo is defined ? messageRepo.countUnread() : 0 %}
        </a>

        <div class="nav-section">Configuration</div>
        <a href="{{ path('admin_settings_edit') }}"
           class="nav-link {% if app.request.attributes.get('_route') == 'admin_settings_edit' %}active{% endif %}">
            <i class="bi bi-gear"></i> Paramètres
        </a>
        <a href="{{ path('admin_landing_edit') }}"
           class="nav-link {% if app.request.attributes.get('_route') == 'admin_landing_edit' %}active{% endif %}">
            <i class="bi bi-palette"></i> Apparence
        </a>

        <div class="nav-section mt-3">Compte</div>
        <a href="{{ path('home', {'_locale': 'fr'}) }}" target="_blank" class="nav-link">
            <i class="bi bi-globe"></i> Voir le site
        </a>
        <a href="{{ path('admin_logout') }}" class="nav-link text-danger">
            <i class="bi bi-box-arrow-left"></i> Déconnexion
        </a>
    </nav>
</aside>

{# Topbar #}
<div class="topbar">
    <h6 class="mb-0 fw-semibold">{% block page_title %}{% endblock %}</h6>
    <div class="d-flex align-items-center gap-3">
        <span class="text-muted small">
            <i class="bi bi-person-circle me-1"></i>{{ app.user ? app.user.userIdentifier : 'admin' }}
        </span>
    </div>
</div>

{# Main content #}
<main class="main-content">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'success' ? 'success' : (type == 'error' ? 'danger' : 'info') }} alert-dismissible fade show mb-3">
                {{ message|trans }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

{{ encore_entry_script_tags('admin') }}
{% block javascripts %}{% endblock %}
</body>
</html>
