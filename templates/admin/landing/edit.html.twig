{% extends 'admin/base.html.twig' %}

{% block title %}Apparence{% endblock %}
{% block page_title %}Personnaliser l'apparence{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                {# Bootstrap nav-tabs #}
                <ul class="nav nav-tabs card-header-tabs" id="landingTabs" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-colors">
                            <i class="bi bi-palette me-1"></i>Couleurs
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-fonts">
                            <i class="bi bi-type me-1"></i>Typographie
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-hero">
                            <i class="bi bi-card-image me-1"></i>Hero
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-sections">
                            <i class="bi bi-layout-text-window me-1"></i>Sections
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-about">
                            <i class="bi bi-info-circle me-1"></i>À propos
                        </button>
                    </li>
                </ul>
            </div>

            <div class="card-body p-4">
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'id': 'landing-form'}}) }}

                <div class="tab-content" id="landingTabsContent">

                    {# ====== TAB: COLORS ====== #}
                    <div class="tab-pane fade show active" id="tab-colors" role="tabpanel">
                        <h6 class="fw-bold mb-4 text-muted text-uppercase small">Palette de couleurs</h6>
                        <div class="row g-3">
                            {% for field in ['colorPrimary','colorSecondary','colorBackground','colorText',
                                             'colorNavbarBg','colorNavbarText','colorFooterBg','colorFooterText'] %}
                            <div class="col-md-6">
                                <div class="d-flex align-items-center gap-3 p-3 border rounded-2">
                                    <div>
                                        {{ form_widget(form[field], {'attr': {'class': 'form-control form-control-color', 'style': 'width:48px;height:48px;cursor:pointer;'}}) }}
                                    </div>
                                    <div class="flex-grow-1">
                                        {{ form_label(form[field], null, {'label_attr': {'class': 'form-label mb-1 fw-semibold small'}}) }}
                                        <div class="small text-muted color-preview-value"></div>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>

                    {# ====== TAB: FONTS ====== #}
                    <div class="tab-pane fade" id="tab-fonts" role="tabpanel">
                        <h6 class="fw-bold mb-4 text-muted text-uppercase small">Typographie</h6>
                        <div class="alert alert-info small">
                            <i class="bi bi-info-circle me-1"></i>
                            Entrez le nom exact d'une police
                            <a href="https://fonts.google.com" target="_blank">Google Fonts</a>
                            (ex: Roboto, Poppins, Cairo, Tajawal).
                        </div>
                        <div class="row g-3">
                            <div class="col-md-5">{{ form_row(form.fontHeading) }}</div>
                            <div class="col-md-5">{{ form_row(form.fontBody) }}</div>
                            <div class="col-md-2">{{ form_row(form.fontSizeBase) }}</div>
                        </div>
                    </div>

                    {# ====== TAB: HERO ====== #}
                    <div class="tab-pane fade" id="tab-hero" role="tabpanel">
                        <h6 class="fw-bold mb-4 text-muted text-uppercase small">Section Hero</h6>
                        <div class="row g-3">
                            <div class="col-12">{{ form_row(form.heroTitle) }}</div>
                            <div class="col-12">{{ form_row(form.heroSubtitle) }}</div>
                            <div class="col-md-6">{{ form_row(form.heroBackgroundImageFile) }}</div>
                            {% if lp.heroBackgroundImage %}
                            <div class="col-md-6">
                                <label class="form-label small text-muted">Image actuelle</label><br>
                                <img src="{{ asset('uploads/hero/' ~ lp.heroBackgroundImage) }}"
                                     class="img-thumbnail" style="max-height:100px;">
                            </div>
                            {% endif %}
                            <div class="col-md-4">
                                <div class="d-flex align-items-center gap-3 p-3 border rounded-2">
                                    {{ form_widget(form.heroBackgroundColor, {'attr': {'class': 'form-control form-control-color', 'style': 'width:48px;height:48px;'}}) }}
                                    <div>{{ form_label(form.heroBackgroundColor, null, {'label_attr': {'class': 'form-label mb-0 small fw-semibold'}}) }}</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="d-flex align-items-center gap-3 p-3 border rounded-2">
                                    {{ form_widget(form.heroTextColor, {'attr': {'class': 'form-control form-control-color', 'style': 'width:48px;height:48px;'}}) }}
                                    <div>{{ form_label(form.heroTextColor, null, {'label_attr': {'class': 'form-label mb-0 small fw-semibold'}}) }}</div>
                                </div>
                            </div>
                            <div class="col-md-12 mt-2">
                                <h6 class="small fw-bold text-muted text-uppercase">Bouton CTA</h6>
                            </div>
                            <div class="col-md-4">{{ form_row(form.heroButtonText) }}</div>
                            <div class="col-md-4">
                                <div class="d-flex align-items-center gap-3 p-3 border rounded-2">
                                    {{ form_widget(form.heroButtonColor, {'attr': {'class': 'form-control form-control-color', 'style': 'width:48px;height:48px;'}}) }}
                                    <div>{{ form_label(form.heroButtonColor, null, {'label_attr': {'class': 'form-label mb-0 small fw-semibold'}}) }}</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="d-flex align-items-center gap-3 p-3 border rounded-2">
                                    {{ form_widget(form.heroButtonTextColor, {'attr': {'class': 'form-control form-control-color', 'style': 'width:48px;height:48px;'}}) }}
                                    <div>{{ form_label(form.heroButtonTextColor, null, {'label_attr': {'class': 'form-label mb-0 small fw-semibold'}}) }}</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# ====== TAB: SECTIONS ====== #}
                    <div class="tab-pane fade" id="tab-sections" role="tabpanel">
                        <h6 class="fw-bold mb-4 text-muted text-uppercase small">Sections de la page</h6>
                        <div class="row g-3">
                            <div class="col-12"><h6 class="small fw-semibold">Section Actualités</h6></div>
                            <div class="col-md-6">{{ form_row(form.actualitesSectionTitle) }}</div>
                            <div class="col-md-6">{{ form_row(form.actualitesSectionSubtitle) }}</div>
                            <div class="col-md-4">
                                <div class="d-flex align-items-center gap-3 p-3 border rounded-2">
                                    {{ form_widget(form.actualitesSectionBg, {'attr': {'class': 'form-control form-control-color', 'style': 'width:48px;height:48px;'}}) }}
                                    <div>{{ form_label(form.actualitesSectionBg, null, {'label_attr': {'class': 'form-label mb-0 small fw-semibold'}}) }}</div>
                                </div>
                            </div>

                            <div class="col-12 mt-3"><hr><h6 class="small fw-semibold">Section Contact</h6></div>
                            <div class="col-md-6">{{ form_row(form.contactSectionTitle) }}</div>
                            <div class="col-md-6">{{ form_row(form.contactSectionSubtitle) }}</div>
                            <div class="col-md-4">
                                <div class="d-flex align-items-center gap-3 p-3 border rounded-2">
                                    {{ form_widget(form.contactSectionBg, {'attr': {'class': 'form-control form-control-color', 'style': 'width:48px;height:48px;'}}) }}
                                    <div>{{ form_label(form.contactSectionBg, null, {'label_attr': {'class': 'form-label mb-0 small fw-semibold'}}) }}</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# ====== TAB: ABOUT ====== #}
                    <div class="tab-pane fade" id="tab-about" role="tabpanel">
                        <h6 class="fw-bold mb-4 text-muted text-uppercase small">Section À propos (optionnelle)</h6>
                        <div class="mb-3 form-check">
                            {{ form_widget(form.aboutEnabled) }}
                            {{ form_label(form.aboutEnabled, null, {'label_attr': {'class': 'form-check-label fw-semibold'}}) }}
                        </div>
                        <div class="row g-3" id="about-fields">
                            <div class="col-12">{{ form_row(form.aboutTitle) }}</div>
                            <div class="col-12">{{ form_row(form.aboutText) }}</div>
                            <div class="col-md-6">{{ form_row(form.aboutImageFile) }}</div>
                            {% if lp.aboutImage %}
                            <div class="col-md-6">
                                <label class="form-label small text-muted">Image actuelle</label><br>
                                <img src="{{ asset('uploads/about/' ~ lp.aboutImage) }}"
                                     class="img-thumbnail" style="max-height:100px;">
                            </div>
                            {% endif %}
                        </div>
                    </div>

                </div>{# /tab-content #}

                <div class="mt-4 pt-3 border-top">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-lg me-2"></i>Enregistrer les modifications
                    </button>
                    <a href="{{ path('home', {'_locale': 'fr'}) }}" target="_blank" class="btn btn-outline-secondary ms-2">
                        <i class="bi bi-eye me-2"></i>Voir le site
                    </a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>

    {# Quick preview panel #}
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm sticky-top" style="top: 80px;">
            <div class="card-body p-3">
                <h6 class="fw-bold mb-3 small text-muted text-uppercase">Aperçu couleurs</h6>
                <div id="color-preview" class="rounded-2 overflow-hidden border">
                    <div class="p-3 text-white" id="preview-hero" style="background: {{ lp.heroBackgroundColor ?? lp.colorPrimary }}">
                        <div class="small fw-bold" id="preview-title">{{ lp.heroTitle }}</div>
                    </div>
                    <div class="p-2 border-bottom" id="preview-navbar" style="background: {{ lp.colorNavbarBg }}">
                        <span class="small fw-semibold" id="preview-nav-text" style="color: {{ lp.colorNavbarText }}">Navbar</span>
                    </div>
                    <div class="p-2" id="preview-bg" style="background: {{ lp.colorBackground }}">
                        <span class="small" id="preview-body-text" style="color: {{ lp.colorText }}">Corps du texte</span>
                    </div>
                    <div class="p-2 text-white" id="preview-footer" style="background: {{ lp.colorFooterBg }}">
                        <span class="small" id="preview-footer-text" style="color: {{ lp.colorFooterText }}">Footer</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
// Live color preview
document.querySelectorAll('input[type="color"]').forEach(input => {
    input.addEventListener('input', function() {
        const fieldId = this.id;
        const value = this.value;

        // Show hex value next to picker
        const container = this.closest('.d-flex');
        if (container) {
            const valueEl = container.querySelector('.color-preview-value');
            if (valueEl) valueEl.textContent = value;
        }

        // Update preview panel
        const map = {
            'landing_page_content_colorNavbarBg':   () => document.getElementById('preview-navbar').style.background = value,
            'landing_page_content_colorNavbarText':  () => document.getElementById('preview-nav-text').style.color = value,
            'landing_page_content_colorBackground':  () => document.getElementById('preview-bg').style.background = value,
            'landing_page_content_colorText':        () => document.getElementById('preview-body-text').style.color = value,
            'landing_page_content_colorFooterBg':    () => document.getElementById('preview-footer').style.background = value,
            'landing_page_content_colorFooterText':  () => document.getElementById('preview-footer-text').style.color = value,
            'landing_page_content_heroBackgroundColor': () => document.getElementById('preview-hero').style.background = value,
        };
        if (map[fieldId]) map[fieldId]();
    });
    input.dispatchEvent(new Event('input'));
});

// Toggle About fields visibility
const aboutToggle = document.getElementById('landing_page_content_aboutEnabled');
const aboutFields = document.getElementById('about-fields');
if (aboutToggle && aboutFields) {
    const toggle = () => aboutFields.style.opacity = aboutToggle.checked ? '1' : '.4';
    toggle();
    aboutToggle.addEventListener('change', toggle);
}
</script>
{% endblock %}
