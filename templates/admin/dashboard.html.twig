{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% block body %}
<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="p-3 rounded-3 bg-primary bg-opacity-10">
                    <i class="bi bi-newspaper fs-3 text-primary"></i>
                </div>
                <div>
                    <div class="display-6 fw-bold">{{ totalActualites }}</div>
                    <div class="text-muted small">Actualités</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="p-3 rounded-3 bg-warning bg-opacity-10">
                    <i class="bi bi-envelope fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="display-6 fw-bold">{{ unreadMessages }}</div>
                    <div class="text-muted small">Messages non lus</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Actions rapides</h6>
                <div class="d-grid gap-2">
                    <a href="{{ path('admin_actualite_new') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Nouvelle actualité
                    </a>
                    <a href="{{ path('admin_message_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-envelope me-2"></i>Voir les messages
                    </a>
                    <a href="{{ path('admin_settings_edit') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-gear me-2"></i>Paramètres du site
                    </a>
                    <a href="{{ path('admin_landing_edit') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-palette me-2"></i>Personnaliser l'apparence
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
