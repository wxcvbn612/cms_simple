{% extends 'admin/base.html.twig' %}

{% block title %}Nouvelle actualité{% endblock %}
{% block page_title %}Nouvelle actualité{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                <div class="mb-3">{{ form_row(form.titre) }}</div>
                <div class="mb-3">{{ form_row(form.contenu) }}</div>
                <div class="mb-3">{{ form_row(form.imageFile) }}</div>
                <div class="row mb-3">
                    <div class="col-md-6">{{ form_row(form.datePublication) }}</div>
                    <div class="col-md-6 d-flex align-items-end pb-1">
                        <div class="form-check">
                            {{ form_widget(form.isPublished) }}
                            {{ form_label(form.isPublished) }}
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-lg me-2"></i>Créer
                    </button>
                    <a href="{{ path('admin_actualite_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
