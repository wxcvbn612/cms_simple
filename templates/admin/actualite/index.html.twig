{% extends 'admin/base.html.twig' %}

{% block title %}Actualités{% endblock %}
{% block page_title %}Gestion des actualités{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted mb-0">{{ actualites|length }} actualité(s) au total</p>
    <a href="{{ path('admin_actualite_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Nouvelle actualité
    </a>
</div>

{% if actualites is empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-newspaper fs-1 mb-3 d-block"></i>
            Aucune actualité pour le moment.
            <br>
            <a href="{{ path('admin_actualite_new') }}" class="btn btn-primary mt-3">Créer la première</a>
        </div>
    </div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">Image</th>
                    <th>Titre</th>
                    <th>Date de publication</th>
                    <th>Statut</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for actualite in actualites %}
                <tr>
                    <td>
                        {% if actualite.image %}
                            <img src="{{ asset('uploads/actualites/' ~ actualite.image) }}"
                                 class="rounded" width="48" height="48" style="object-fit:cover;">
                        {% else %}
                            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                                <i class="bi bi-image text-muted"></i>
                            </div>
                        {% endif %}
                    </td>
                    <td>
                        <div class="fw-semibold">{{ actualite.titre }}</div>
                        <small class="text-muted">{{ actualite.contenu|slice(0, 60) }}…</small>
                    </td>
                    <td class="text-muted small">{{ actualite.datePublication|date('d/m/Y H:i') }}</td>
                    <td>
                        {% if actualite.isPublished %}
                            <span class="badge bg-success">Publié</span>
                        {% else %}
                            <span class="badge bg-secondary">Brouillon</span>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        <a href="{{ path('admin_actualite_edit', {'id': actualite.id}) }}"
                           class="btn btn-sm btn-outline-primary me-1">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('admin_actualite_toggle', {'id': actualite.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ actualite.id) }}">
                            <button class="btn btn-sm btn-outline-{{ actualite.isPublished ? 'warning' : 'success' }}"
                                    title="{{ actualite.isPublished ? 'Dépublier' : 'Publier' }}">
                                <i class="bi bi-{{ actualite.isPublished ? 'eye-slash' : 'eye' }}"></i>
                            </button>
                        </form>
                        <form method="post" action="{{ path('admin_actualite_delete', {'id': actualite.id}) }}" class="d-inline"
                              onsubmit="return confirm('Supprimer cette actualité ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ actualite.id) }}">
                            <button class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
