{% extends 'base.html.twig' %}

{% block title %}{{ settings.siteName }}{% endblock %}

{% block navbar %}
<nav class="navbar navbar-expand-lg sticky-top shadow-sm" style="background-color: var(--color-navbar-bg);">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('home', {'_locale': app.request.locale}) }}" style="color: var(--color-navbar-text);">
            {% if settings.logoFilename %}
                <img src="{{ asset('uploads/logo/' ~ settings.logoFilename) }}" alt="{{ settings.siteName }}" height="40">
            {% else %}
                {{ settings.siteName }}
            {% endif %}
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav ms-auto align-items-center gap-2">
                <li class="nav-item">
                    <a class="nav-link" href="#actualites" style="color: var(--color-navbar-text);">
                        {{ lp.actualitesSectionTitle }}
                    </a>
                </li>
                {% if lp.servicesEnabled %}
                    <li class="nav-item">
                        <a class="nav-link" href="#services" style="color: var(--color-navbar-text);">
                            {{ lp.servicesTitle }}
                        </a>
                    </li>
                {% endif %}
                <li class="nav-item">
                    <a class="nav-link" href="#contact" style="color: var(--color-navbar-text);">
                        {{ lp.contactSectionTitle }}
                    </a>
                </li>
                {% if settings.showSocialInNavbar %}
                    {% if settings.facebookUrl %}<li class="nav-item"><a class="nav-link" href="{{ settings.facebookUrl }}" target="_blank" style="color: var(--color-navbar-text);"><i class="bi bi-facebook"></i></a></li>{% endif %}
                    {% if settings.instagramUrl %}<li class="nav-item"><a class="nav-link" href="{{ settings.instagramUrl }}" target="_blank" style="color: var(--color-navbar-text);"><i class="bi bi-instagram"></i></a></li>{% endif %}
                    {% if settings.xUrl %}<li class="nav-item"><a class="nav-link" href="{{ settings.xUrl }}" target="_blank" style="color: var(--color-navbar-text);"><i class="bi bi-twitter-x"></i></a></li>{% endif %}
                    {% if settings.linkedinUrl %}<li class="nav-item"><a class="nav-link" href="{{ settings.linkedinUrl }}" target="_blank" style="color: var(--color-navbar-text);"><i class="bi bi-linkedin"></i></a></li>{% endif %}
                    {% if settings.youtubeUrl %}<li class="nav-item"><a class="nav-link" href="{{ settings.youtubeUrl }}" target="_blank" style="color: var(--color-navbar-text);"><i class="bi bi-youtube"></i></a></li>{% endif %}
                    {% if settings.tiktokUrl %}<li class="nav-item"><a class="nav-link" href="{{ settings.tiktokUrl }}" target="_blank" style="color: var(--color-navbar-text);"><i class="bi bi-tiktok"></i></a></li>{% endif %}
                    {% if settings.whatsapp %}<li class="nav-item"><a class="nav-link" href="https://wa.me/{{ settings.whatsapp|replace({'+': '', ' ': ''}) }}" target="_blank" style="color: var(--color-navbar-text);"><i class="bi bi-whatsapp"></i></a></li>{% endif %}
                {% endif %}
                {# Language switcher #}
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" style="color: var(--color-navbar-text);">
                        {% if app.request.locale == 'ar' %}🇩🇿 عربي{% else %}🇫🇷 FR{% endif %}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="{{ path('home', {'_locale': 'fr'}) }}">🇫🇷 Français</a></li>
                        <li><a class="dropdown-item" href="{{ path('home', {'_locale': 'ar'}) }}">🇩🇿 عربي</a></li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav>
{% endblock %}

{% block body %}
{% set orderedSections = (lp.sectionOrder ?? 'hero,about,actualites,services,social,faq,testimonials,gallery,partners,cta,contact')|split(',') %}

{% for section in orderedSections %}
    {% set section = section|trim %}

    {% if section == 'hero' %}
        <section id="hero" class="py-5 d-flex align-items-center min-vh-75" style="{% if lp.heroBackgroundImage %}background: url('{{ asset('uploads/hero/' ~ lp.heroBackgroundImage) }}') center/cover no-repeat;{% else %}background-color: {{ lp.heroBackgroundColor ?? lp.colorPrimary }};{% endif %}color: {{ lp.heroTextColor }};min-height: 75vh;">
            <div class="container text-center">
                <h1 class="display-3 fw-bold mb-3">{{ lp.heroTitle }}</h1>
                {% if lp.heroSubtitle %}<p class="lead mb-4 fs-4">{{ lp.heroSubtitle }}</p>{% endif %}
                <a href="#contact" class="btn btn-lg px-5 py-3 fw-semibold" style="background-color: {{ lp.heroButtonColor }}; color: {{ lp.heroButtonTextColor }}; border: none;">{{ lp.heroButtonText }}</a>
            </div>
        </section>
    {% elseif section == 'about' and lp.aboutEnabled %}
        <section id="about" class="py-5">
            <div class="container">
                <div class="row align-items-center g-4">
                    {% if lp.aboutImage %}
                        <div class="col-md-5"><img src="{{ asset('uploads/about/' ~ lp.aboutImage) }}" alt="{{ lp.aboutTitle }}" class="img-fluid rounded shadow"></div>
                        <div class="col-md-7">
                    {% else %}
                        <div class="col-12">
                    {% endif %}
                            <h2 class="fw-bold mb-3">{{ lp.aboutTitle }}</h2>
                            <div>{{ lp.aboutText|nl2br }}</div>
                        </div>
                </div>
            </div>
        </section>
    {% elseif section == 'actualites' %}
        <section id="actualites" class="py-5" style="background-color: {{ lp.actualitesSectionBg }};">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="fw-bold">{{ lp.actualitesSectionTitle }}</h2>
                    {% if lp.actualitesSectionSubtitle %}<p class="text-muted lead">{{ lp.actualitesSectionSubtitle }}</p>{% endif %}
                </div>
                {% if actualites is empty %}
                    <p class="text-center text-muted">{{ 'actualites.empty'|trans }}</p>
                {% else %}
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                        {% for actualite in actualites %}
                            <div class="col"><div class="card h-100 shadow-sm border-0">{% if actualite.image %}<img src="{{ asset('uploads/actualites/' ~ actualite.image) }}" class="card-img-top" alt="{{ actualite.titre }}" style="height: 200px; object-fit: cover;">{% endif %}<div class="card-body"><h5 class="card-title fw-semibold">{{ actualite.titre }}</h5><p class="card-text text-muted small">{{ actualite.datePublication|date('d/m/Y') }}</p><p class="card-text">{{ actualite.contenu|slice(0, 150) }}{% if actualite.contenu|length > 150 %}…{% endif %}</p></div></div></div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </section>
    {% elseif section == 'services' and lp.servicesEnabled %}
        <section id="services" class="py-5" style="background-color: {{ lp.servicesBg }};">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="fw-bold">{{ lp.servicesTitle }}</h2>
                    {% if lp.servicesSubtitle %}<p class="text-muted lead">{{ lp.servicesSubtitle }}</p>{% endif %}
                </div>
                <div class="row g-4">
                    {% for service in [
                        {title: lp.serviceCard1Title, description: lp.serviceCard1Description, image: lp.serviceCard1Image},
                        {title: lp.serviceCard2Title, description: lp.serviceCard2Description, image: lp.serviceCard2Image},
                        {title: lp.serviceCard3Title, description: lp.serviceCard3Description, image: lp.serviceCard3Image}
                    ] %}
                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                {% if service.image %}
                                    <img src="{{ asset('uploads/services/' ~ service.image) }}" alt="{{ service.title }}" class="card-img-top" style="height: 220px; object-fit: cover;">
                                {% endif %}
                                <div class="card-body">
                                    <h5 class="card-title fw-semibold">{{ service.title }}</h5>
                                    {% if service.description %}<p class="card-text text-muted mb-0">{{ service.description }}</p>{% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% elseif section == 'social' and lp.socialBlockEnabled %}
        <section id="social" class="py-5" style="background-color: {{ lp.socialBlockBg }};">
            <div class="container text-center">
                <h2 class="fw-bold">{{ lp.socialBlockTitle }}</h2>
                {% if lp.socialBlockSubtitle %}<p class="text-muted lead">{{ lp.socialBlockSubtitle }}</p>{% endif %}
                <div class="d-flex justify-content-center gap-3 mt-3 fs-3">
                    {% if settings.facebookUrl %}<a href="{{ settings.facebookUrl }}" target="_blank" style="color: var(--color-primary);"><i class="bi bi-facebook"></i></a>{% endif %}
                    {% if settings.instagramUrl %}<a href="{{ settings.instagramUrl }}" target="_blank" style="color: var(--color-primary);"><i class="bi bi-instagram"></i></a>{% endif %}
                    {% if settings.xUrl %}<a href="{{ settings.xUrl }}" target="_blank" style="color: var(--color-primary);"><i class="bi bi-twitter-x"></i></a>{% endif %}
                    {% if settings.linkedinUrl %}<a href="{{ settings.linkedinUrl }}" target="_blank" style="color: var(--color-primary);"><i class="bi bi-linkedin"></i></a>{% endif %}
                    {% if settings.youtubeUrl %}<a href="{{ settings.youtubeUrl }}" target="_blank" style="color: var(--color-primary);"><i class="bi bi-youtube"></i></a>{% endif %}
                    {% if settings.tiktokUrl %}<a href="{{ settings.tiktokUrl }}" target="_blank" style="color: var(--color-primary);"><i class="bi bi-tiktok"></i></a>{% endif %}
                    {% if settings.whatsapp %}<a href="https://wa.me/{{ settings.whatsapp|replace({'+': '', ' ': ''}) }}" target="_blank" style="color: var(--color-primary);"><i class="bi bi-whatsapp"></i></a>{% endif %}
                </div>
            </div>
        </section>
    {% elseif section == 'faq' and lp.faqEnabled %}
        <section id="faq" class="py-5" style="background-color: {{ lp.faqBg }};">
            <div class="container">
                <div class="text-center mb-4"><h2 class="fw-bold">{{ lp.faqTitle }}</h2>{% if lp.faqSubtitle %}<p class="text-muted">{{ lp.faqSubtitle }}</p>{% endif %}</div>
                <div class="accordion" id="faqAccordion">
                    {% set faqItems = [
                        {q: lp.faqQ1, a: lp.faqA1},
                        {q: lp.faqQ2, a: lp.faqA2},
                        {q: lp.faqQ3, a: lp.faqA3}
                    ] %}
                    {% for i, item in faqItems %}
                        {% if item.q %}
                        <div class="accordion-item">
                            <h2 class="accordion-header"><button class="accordion-button {{ i > 0 ? 'collapsed' : '' }}" type="button" data-bs-toggle="collapse" data-bs-target="#faq-{{ i }}">{{ item.q }}</button></h2>
                            <div id="faq-{{ i }}" class="accordion-collapse collapse {{ i == 0 ? 'show' : '' }}" data-bs-parent="#faqAccordion"><div class="accordion-body">{{ item.a }}</div></div>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </section>
    {% elseif section == 'testimonials' and lp.testimonialsEnabled %}
        <section id="testimonials" class="py-5" style="background-color: {{ lp.testimonialsBg }};">
            <div class="container">
                <div class="text-center mb-4"><h2 class="fw-bold">{{ lp.testimonialsTitle }}</h2>{% if lp.testimonialsSubtitle %}<p class="text-muted">{{ lp.testimonialsSubtitle }}</p>{% endif %}</div>
                <div class="row g-3">
                    {% set testimonials = [
                        {text: lp.testimonial1Text, author: lp.testimonial1Author, role: lp.testimonial1Role},
                        {text: lp.testimonial2Text, author: lp.testimonial2Author, role: lp.testimonial2Role},
                        {text: lp.testimonial3Text, author: lp.testimonial3Author, role: lp.testimonial3Role}
                    ] %}
                    {% for t in testimonials %}
                        {% if t.text %}
                        <div class="col-md-4"><div class="card h-100 border-0 shadow-sm"><div class="card-body d-flex flex-column"><p class="mb-3 flex-grow-1">"{{ t.text }}"</p><div class="small fw-semibold">{{ t.author }}</div>{% if t.role %}<div class="small text-muted">{{ t.role }}</div>{% endif %}</div></div></div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </section>
    {% elseif section == 'gallery' and lp.galleryEnabled %}
        <section id="gallery" class="py-5" style="background-color: {{ lp.galleryBg }};">
            <div class="container">
                <div class="text-center mb-4"><h2 class="fw-bold">{{ lp.galleryTitle }}</h2>{% if lp.gallerySubtitle %}<p class="text-muted">{{ lp.gallerySubtitle }}</p>{% endif %}</div>
                <div class="row g-3">
                    {% set galleryItems = [
                        {image: lp.galleryImage1, caption: lp.galleryCaption1},
                        {image: lp.galleryImage2, caption: lp.galleryCaption2},
                        {image: lp.galleryImage3, caption: lp.galleryCaption3},
                        {image: lp.galleryImage4, caption: lp.galleryCaption4},
                        {image: lp.galleryImage5, caption: lp.galleryCaption5},
                        {image: lp.galleryImage6, caption: lp.galleryCaption6}
                    ] %}
                    {% for item in galleryItems %}
                        {% if item.image %}
                        <div class="col-6 col-md-4">
                            <div class="rounded overflow-hidden border bg-white">
                                <img src="{{ asset('uploads/gallery/' ~ item.image) }}" alt="{{ item.caption }}" class="img-fluid w-100" style="height:200px;object-fit:cover;">
                                {% if item.caption %}<div class="p-2 text-center small text-muted">{{ item.caption }}</div>{% endif %}
                            </div>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </section>
    {% elseif section == 'partners' and lp.partnersEnabled %}
        <section id="partners" class="py-5" style="background-color: {{ lp.partnersBg }};">
            <div class="container">
                <div class="text-center mb-4"><h2 class="fw-bold">{{ lp.partnersTitle }}</h2>{% if lp.partnersSubtitle %}<p class="text-muted">{{ lp.partnersSubtitle }}</p>{% endif %}</div>
                <div class="row g-3 align-items-center justify-content-center">
                    {% set partners = [
                        {name: lp.partnerName1, logo: lp.partnerLogo1},
                        {name: lp.partnerName2, logo: lp.partnerLogo2},
                        {name: lp.partnerName3, logo: lp.partnerLogo3},
                        {name: lp.partnerName4, logo: lp.partnerLogo4},
                        {name: lp.partnerName5, logo: lp.partnerLogo5},
                        {name: lp.partnerName6, logo: lp.partnerLogo6}
                    ] %}
                    {% for p in partners %}
                        {% if p.name or p.logo %}
                        <div class="col-6 col-md-2 text-center">
                            <div class="border rounded py-3 px-2 bg-white h-100 d-flex flex-column align-items-center justify-content-center">
                                {% if p.logo %}<img src="{{ asset('uploads/partners/' ~ p.logo) }}" alt="{{ p.name }}" class="img-fluid mb-1" style="max-height:60px;object-fit:contain;">{% endif %}
                                {% if p.name %}<div class="small fw-semibold">{{ p.name }}</div>{% endif %}
                            </div>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </section>
    {% elseif section == 'cta' and lp.ctaBlockEnabled %}
        <section id="cta" class="py-5" style="background-color: {{ lp.ctaBlockBg }}; color: {{ lp.ctaTextColor }};">
            <div class="container text-center">
                <h2 class="fw-bold">{{ lp.ctaBlockTitle }}</h2>
                {% if lp.ctaBlockText %}<p class="lead">{{ lp.ctaBlockText }}</p>{% endif %}
                <a href="{{ lp.ctaButtonLink }}" class="btn btn-light btn-lg px-4">{{ lp.ctaButtonText }}</a>
            </div>
        </section>
    {% elseif section == 'contact' %}
        <section id="contact" class="py-5" style="background-color: {{ lp.contactSectionBg }};">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="fw-bold">{{ lp.contactSectionTitle }}</h2>
                    {% if lp.contactSectionSubtitle %}<p class="text-muted lead">{{ lp.contactSectionSubtitle }}</p>{% endif %}
                </div>
                <div class="row justify-content-center">
                    <div class="col-lg-6">
                        <div class="mb-4">
                            {% if settings.phone %}<p><i class="bi bi-telephone me-2" style="color: var(--color-primary);"></i>{{ settings.phone }}</p>{% endif %}
                            {% if settings.email %}<p><i class="bi bi-envelope me-2" style="color: var(--color-primary);"></i>{{ settings.email }}</p>{% endif %}
                            {% if settings.address %}<p><i class="bi bi-geo-alt me-2" style="color: var(--color-primary);"></i>{{ settings.address }}</p>{% endif %}
                        </div>
                        <div class="text-center"><a href="{{ path('contact', {'_locale': app.request.locale}) }}" class="btn btn-lg px-5" style="background-color: var(--color-primary); color: #fff; border: none;">{{ 'contact.open_form'|trans }}</a></div>
                    </div>
                </div>
            </div>
        </section>
    {% endif %}
{% endfor %}

{% endblock %}

{% block footer %}
<footer class="py-4" style="background-color: var(--color-footer-bg); color: var(--color-footer-text);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-4 mb-2 mb-md-0">
                <strong>{{ settings.siteName }}</strong>
                {% if settings.siteTagline %}
                    <br><small>{{ settings.siteTagline }}</small>
                {% endif %}
            </div>
            <div class="col-md-4 text-center mb-2 mb-md-0">
                {% if settings.footerText %}
                    <small>{{ settings.footerText }}</small>
                {% endif %}
            </div>
            <div class="col-md-4 text-md-end">
                {% if settings.showSocialInFooter %}
                    {% if settings.facebookUrl %}<a href="{{ settings.facebookUrl }}" target="_blank" class="me-2" style="color: var(--color-footer-text);"><i class="bi bi-facebook fs-5"></i></a>{% endif %}
                    {% if settings.instagramUrl %}<a href="{{ settings.instagramUrl }}" target="_blank" class="me-2" style="color: var(--color-footer-text);"><i class="bi bi-instagram fs-5"></i></a>{% endif %}
                    {% if settings.xUrl %}<a href="{{ settings.xUrl }}" target="_blank" class="me-2" style="color: var(--color-footer-text);"><i class="bi bi-twitter-x fs-5"></i></a>{% endif %}
                    {% if settings.linkedinUrl %}<a href="{{ settings.linkedinUrl }}" target="_blank" class="me-2" style="color: var(--color-footer-text);"><i class="bi bi-linkedin fs-5"></i></a>{% endif %}
                    {% if settings.youtubeUrl %}<a href="{{ settings.youtubeUrl }}" target="_blank" class="me-2" style="color: var(--color-footer-text);"><i class="bi bi-youtube fs-5"></i></a>{% endif %}
                    {% if settings.tiktokUrl %}<a href="{{ settings.tiktokUrl }}" target="_blank" class="me-2" style="color: var(--color-footer-text);"><i class="bi bi-tiktok fs-5"></i></a>{% endif %}
                    {% if settings.whatsapp %}<a href="https://wa.me/{{ settings.whatsapp|replace({'+': '', ' ': ''}) }}" target="_blank" style="color: var(--color-footer-text);"><i class="bi bi-whatsapp fs-5"></i></a>{% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</footer>
{% endblock %}
